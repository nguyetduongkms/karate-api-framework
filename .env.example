# ================================================================
# ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and fill in the actual values.
# .env is gitignored and must NEVER be committed to source control.
# In CI/CD pipelines, set these as native environment variables.
# ================================================================

# Demo account (primary account used in login tests)
DEMO_USERNAME=
DEMO_PASSWORD=
DEMO_EMAIL=

# Password used when registering a new test user (register happy-path scenario)
NEW_USER_PASSWORD=

# Existing user account (used in negative registration test — must already exist on server)
EXISTING_USERNAME=
EXISTING_PASSWORD=
EXISTING_EMAIL=
